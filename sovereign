#!/bin/bash

# sovereign - Server Management CLI

PROJECT_ROOT=$(dirname "$(readlink -f "$0")")
PLATFORM="podman" # Default platform

function usage() {
    echo "Usage: sovereign [command] [target]"
    echo ""
    echo "Commands:"
    echo "  up [target]      Start a service (core or app)"
    echo "  down [target]    Stop a service"
    echo "  restart [target] Restart a service"
    echo "  ps               List running services"
    echo "  logs [target]    Show logs for a service"
    echo ""
    echo "Targets (for Podman):"
    echo "  core/traefik"
    echo "  core/smtp"
    echo "  apps/immich"
    echo "  ..."
}

if [ -f "$PROJECT_ROOT/.env" ]; then
    ENV_FILE="--env-file $PROJECT_ROOT/.env"
else
    ENV_FILE=""
    echo "Warning: .env file not found. Using system environment variables."
fi

command=$1
target=$2

case $command in
    up)
        if [ -d "$PROJECT_ROOT/$PLATFORM/$target" ]; then
            cd "$PROJECT_ROOT/$PLATFORM/$target" && podman compose $ENV_FILE up -d
        else
            echo "Target $PLATFORM/$target not found."
        fi
        ;;
    down)
        if [ -d "$PROJECT_ROOT/$PLATFORM/$target" ]; then
            cd "$PROJECT_ROOT/$PLATFORM/$target" && podman compose $ENV_FILE down
        else
            echo "Target $PLATFORM/$target not found."
        fi
        ;;
    restart)
        if [ -d "$PROJECT_ROOT/$PLATFORM/$target" ]; then
            cd "$PROJECT_ROOT/$PLATFORM/$target" && podman compose $ENV_FILE restart
        else
            echo "Target $PLATFORM/$target not found."
        fi
        ;;
    logs)
        if [ -d "$PROJECT_ROOT/$PLATFORM/$target" ]; then
            cd "$PROJECT_ROOT/$PLATFORM/$target" && podman compose $ENV_FILE logs -f
        else
            echo "Target $PLATFORM/$target not found."
        fi
        ;;
    ps)
        podman ps --filter "label=com.docker.compose.project"
        ;;
    *)
        usage
        ;;
esac
